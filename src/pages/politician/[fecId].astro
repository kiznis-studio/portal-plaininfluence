---
import Base from '../../layouts/Base.astro';
import AdSlot from '../../components/ads/AdSlot.astro';
import { getPolitician, getPoliticianDonors } from '../../lib/db';

const db = Astro.locals.runtime.env.DB;
const { fecId } = Astro.params;

const [politician, donors] = await Promise.all([
  getPolitician(db, fecId || ''),
  getPoliticianDonors(db, fecId || '', 50),
]);

if (!politician) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

function fmtMoney(n: number | null): string {
  if (n == null) return 'N/A';
  if (n >= 1e9) return '$' + (n / 1e9).toFixed(1) + 'B';
  if (n >= 1e6) return '$' + (n / 1e6).toFixed(1) + 'M';
  if (n >= 1e3) return '$' + (n / 1e3).toFixed(0) + 'K';
  return '$' + n.toLocaleString();
}

function partyFull(p: string | null): string {
  if (p === 'DEM') return 'Democrat';
  if (p === 'REP') return 'Republican';
  if (p === 'IND') return 'Independent';
  if (p === 'LIB') return 'Libertarian';
  if (p === 'GRE') return 'Green';
  return p || 'Unknown';
}

function partyClass(p: string | null): string {
  if (p === 'DEM') return 'text-blue-600 dark:text-blue-400';
  if (p === 'REP') return 'text-red-600 dark:text-red-400';
  return 'text-[var(--color-muted)]';
}

function partyShort(p: string | null): string {
  if (p === 'DEM') return 'D';
  if (p === 'REP') return 'R';
  if (p === 'IND') return 'I';
  return p || '?';
}

function officeLabel(o: string | null): string {
  if (o === 'P') return 'President';
  if (o === 'S') return 'Senate';
  if (o === 'H') return 'House';
  return o || '';
}

const topDonorName = donors.length > 0 ? donors[0].name : null;
const topDonorAmount = donors.length > 0 ? fmtMoney(donors[0].contribution_amount) : null;

const faqItems = [
  {
    q: `Who funds ${politician.name}'s campaign?`,
    a: `${politician.name} receives campaign contributions from PACs and organizational committees. ${topDonorName ? `The top contributing organization is ${topDonorName}, which contributed ${topDonorAmount}.` : ''} In total, ${politician.name} received ${fmtMoney(politician.total_received)} during the 2024 election cycle from ${donors.length} contributing organizations tracked in FEC filings.`
  },
  {
    q: `How much has ${politician.name} received in total contributions?`,
    a: `${politician.name} (${partyFull(politician.party)}${politician.state ? ', ' + politician.state : ''}) received ${fmtMoney(politician.total_received)} in PAC and organizational contributions during the 2024 federal election cycle. ${politician.incumbent ? 'As an incumbent, ' + politician.name + ' may benefit from established donor relationships.' : ''} All data comes from Federal Election Commission filings.`
  },
  {
    q: `What office is ${politician.name} running for?`,
    a: `${politician.name} is a ${partyFull(politician.party)} candidate for ${officeLabel(politician.office)}${politician.state ? ' in ' + politician.state : ''}${politician.district ? ', District ' + politician.district : ''}. ${politician.incumbent ? politician.name + ' is the incumbent.' : politician.name + ' is a challenger or running for an open seat.'}`
  }
];

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a }
  }))
});

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Politicians', href: '/politicians/' },
  { name: politician.name },
];

---

<Base
  title={`${politician.name} (${partyShort(politician.party)}-${politician.state || 'US'}) — ${fmtMoney(politician.total_received)} Total Received`}
  description={`Campaign finance profile for ${politician.name}. ${officeLabel(politician.office)} candidate, ${partyFull(politician.party)} party. Total PAC contributions: ${fmtMoney(politician.total_received)}.`}
  breadcrumbs={breadcrumbs}
>
  <section class="py-10 md:py-14">
    <div class="container">
      <h1 class="text-3xl md:text-4xl font-bold mb-2">{politician.name}</h1>
      <p class="text-[var(--color-muted)] mb-8">
        <span class={partyClass(politician.party)}>{partyFull(politician.party)}</span>
        {politician.state ? ` - ${politician.state}` : ''}
        {politician.district ? `, District ${politician.district}` : ''}
        &middot; {officeLabel(politician.office)}
      </p>

      <!-- Summary Cards -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
        <div class="card">
          <div class="text-sm text-[var(--color-muted)] mb-1">Total Received</div>
          <div class="text-2xl font-bold">{fmtMoney(politician.total_received)}</div>
          <div class="text-xs text-[var(--color-muted)] mt-1">2024 election cycle</div>
        </div>
        <div class="card">
          <div class="text-sm text-[var(--color-muted)] mb-1">Office</div>
          <div class="text-2xl font-bold">{officeLabel(politician.office)}</div>
          <div class="text-xs text-[var(--color-muted)] mt-1">{politician.incumbent ? 'Incumbent' : 'Challenger/Open'}</div>
        </div>
        <div class="card">
          <div class="text-sm text-[var(--color-muted)] mb-1">Top Donors</div>
          <div class="text-2xl font-bold">{donors.length}</div>
          <div class="text-xs text-[var(--color-muted)] mt-1">Contributing organizations</div>
        </div>
      </div>

      <!-- Money Flow Narrative -->
      <div class="mb-10 max-w-3xl">
        <h2 class="text-2xl font-bold mb-4">Campaign Finance Summary</h2>
        <p class="text-[var(--color-muted)] leading-relaxed">
          {politician.name} ({partyShort(politician.party)}-{politician.state || 'US'}) has received {fmtMoney(politician.total_received)} in
          PAC and organizational contributions during the 2024 federal election cycle.
          {donors.length > 0 ? ` The largest single contribution came from ${donors[0].name}, totaling ${fmtMoney(donors[0].contribution_amount)}.` : ''}
          {donors.length >= 10
            ? ` The top 10 contributing organizations account for a significant portion of total receipts, reflecting concentrated donor support from key interest groups.`
            : ''}
          {politician.incumbent
            ? ' As an incumbent, established donor networks and name recognition typically provide a fundraising advantage.'
            : ' As a non-incumbent candidate, building a donor base is a critical component of campaign viability.'}
        </p>
        <p class="text-[var(--color-muted)] leading-relaxed mt-3">
          These contributions come from PACs and organizational committees registered with the Federal Election Commission.
          Individual contributions are reported separately and are not included in these totals.
          Understanding who funds a candidate provides transparency into the interests that may influence policy priorities.
        </p>
      </div>

      <AdSlot position="mid" />

      <!-- Top Donors -->
      {donors.length > 0 && (
        <div class="mb-10">
          <h2 class="text-2xl font-bold mb-4">Top Donors</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-left">
              <thead>
                <tr class="border-b border-[var(--color-border)]">
                  <th class="py-3 px-4 text-sm font-medium text-[var(--color-muted)]">Organization</th>
                  <th class="py-3 px-4 text-sm font-medium text-[var(--color-muted)] hidden sm:table-cell">Type</th>
                  <th class="py-3 px-4 text-sm font-medium text-[var(--color-muted)] text-right">Amount</th>
                </tr>
              </thead>
              <tbody>
                {donors.map(d => (
                  <tr class="border-b border-[var(--color-border)] hover:bg-[var(--color-card)]">
                    <td class="py-3 px-4">
                      <a href={`/organization/${d.id}`} class="text-[var(--color-accent)] hover:underline font-medium">{d.name}</a>
                    </td>
                    <td class="py-3 px-4 text-sm capitalize hidden sm:table-cell">{d.type || 'N/A'}</td>
                    <td class="py-3 px-4 text-right font-medium">{fmtMoney(d.contribution_amount)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

      <!-- FAQ Section -->
      <div class="mb-10">
        <h2 class="text-2xl font-bold mb-4">Frequently Asked Questions</h2>
        <div class="max-w-3xl space-y-3">
          {faqItems.map(item => (
            <details class="card group">
              <summary class="cursor-pointer font-medium text-[var(--color-foreground)] flex items-center justify-between list-none">
                <span>{item.q}</span>
                <svg class="w-5 h-5 text-[var(--color-muted)] transition-transform group-open:rotate-180 shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-3 text-sm text-[var(--color-muted)] leading-relaxed">{item.a}</p>
            </details>
          ))}
        </div>
      </div>

      <!-- Cross-Links -->
      <div class="mb-10">
        <h2 class="text-xl font-bold mb-4">Related Data</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <a href="https://plainspending.com/" class="card hover:no-underline" target="_blank" rel="noopener">
            <div class="font-medium text-[var(--color-foreground)]">Federal Spending</div>
            <div class="text-sm text-[var(--color-muted)]">Where federal dollars go — contracts, grants, and agency spending by state</div>
          </a>
          <a href="https://plaingovjobs.com/" class="card hover:no-underline" target="_blank" rel="noopener">
            <div class="font-medium text-[var(--color-foreground)]">Federal Workforce</div>
            <div class="text-sm text-[var(--color-muted)]">OPM federal employment data — agencies, occupations, and pay</div>
          </a>
          <a href="https://plainvisa.com/" class="card hover:no-underline" target="_blank" rel="noopener">
            <div class="font-medium text-[var(--color-foreground)]">H-1B Visa Data</div>
            <div class="text-sm text-[var(--color-muted)]">DOL labor condition applications — employers, wages, and locations</div>
          </a>
        </div>
      </div>

      <!-- Content Narrative -->
      <div class="mb-10">
        <h2 class="text-xl font-bold mb-3">Campaign Finance Context</h2>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed max-w-3xl">
          {politician.name}'s {fmtMoney(politician.total_received)} in PAC contributions reflects the financial support network behind this {officeLabel(politician.office).toLowerCase()} {politician.incumbent ? 'incumbent' : 'candidate'}. PAC contributions represent organizational support — from corporations, trade associations, and ideological groups — and are distinct from individual donations. Understanding who funds a campaign provides transparency into potential policy alignment and constituent priorities.
        </p>
      </div>

      <!-- FAQ Section -->
      <div class="mb-10">
        <h2 class="text-xl font-bold mb-4">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqItems.map(f => (
            <details class="card group">
              <summary class="cursor-pointer font-medium flex items-center justify-between list-none p-4">
                <span>{f.q}</span>
                <svg class="w-4 h-4 text-[var(--color-muted)] transition-transform group-open:rotate-180 shrink-0 ml-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <div class="px-4 pb-4 text-sm text-[var(--color-muted)]">{f.a}</div>
            </details>
          ))}
        </div>
      </div>

      <p class="text-xs text-[var(--color-muted)]">
        Data: Federal Election Commission, 2024 cycle. Contributions shown are from PACs and organizational committees.
      </p>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Dataset",
    "name": `${politician.name} Campaign Finance`,
    "description": `Campaign contributions received by ${politician.name} (${partyFull(politician.party)}, ${politician.state || 'US'}).`,
    "url": `https://plaininfluence.com/politician/${politician.fec_id}`,
    "creator": { "@type": "Organization", "name": "Federal Election Commission" },
    "temporalCoverage": "2024",
    "license": "https://www.usa.gov/government-copyright"
  })} />
  <script type="application/ld+json" set:html={faqSchema} />
  <script type="application/ld+json" set:html={faqSchema} />
</Base>
