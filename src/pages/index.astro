---
import Base from '../layouts/Base.astro';
import { getStat, getPoliticianList, getEntityList, getIssueList } from '../lib/db';

const db = Astro.locals.runtime.env.DB;

const [politicianCount, entityCount, totalContributions, totalLobbying, topPoliticians, topEntities, topIssues] = await Promise.all([
  getStat(db, 'politician_count'),
  getStat(db, 'entity_count'),
  getStat(db, 'total_pac_contributions'),
  getStat(db, 'total_lobbying_spending'),
  getPoliticianList(db),
  getEntityList(db),
  getIssueList(db),
]);

function fmtMoney(n: number | null): string {
  if (n == null) return 'N/A';
  if (n >= 1e9) return '$' + (n / 1e9).toFixed(1) + 'B';
  if (n >= 1e6) return '$' + (n / 1e6).toFixed(1) + 'M';
  if (n >= 1e3) return '$' + (n / 1e3).toFixed(0) + 'K';
  return '$' + n.toLocaleString();
}

function fmtNum(n: string | null): string {
  if (n == null) return '0';
  return parseInt(n).toLocaleString();
}

function partyClass(party: string | null): string {
  if (party === 'DEM') return 'text-blue-600 dark:text-blue-400';
  if (party === 'REP') return 'text-red-600 dark:text-red-400';
  return 'text-[var(--color-muted)]';
}

function partyLabel(party: string | null): string {
  if (party === 'DEM') return 'D';
  if (party === 'REP') return 'R';
  if (party === 'IND') return 'I';
  if (party === 'LIB') return 'L';
  return party || '?';
}

function officeLabel(office: string | null): string {
  if (office === 'P') return 'President';
  if (office === 'S') return 'Senate';
  if (office === 'H') return 'House';
  return office || '';
}
---

<Base
  title="PlainInfluence — Follow the Money in U.S. Politics"
  description="Campaign donations, lobbying expenditures, and federal contracts in one place. Track who funds politicians and who profits from government spending."
>
  <!-- Hero -->
  <section class="py-12 md:py-20 bg-gradient-to-b from-indigo-50/50 to-transparent dark:from-indigo-950/20 dark:to-transparent">
    <div class="container text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Follow the <span class="text-[var(--color-accent)]">money</span>
      </h1>
      <p class="text-lg text-[var(--color-muted)] max-w-2xl mx-auto mb-8">
        Campaign donations, lobbying expenditures, and federal contracts — all from official
        federal sources, linked by entity resolution.
      </p>

      <form action="/search" method="get" class="max-w-xl mx-auto mb-10">
        <div class="flex gap-2">
          <input
            type="text"
            name="q"
            placeholder="Search politicians or organizations..."
            class="input flex-1"
            autocomplete="off"
          />
          <button type="submit" class="btn btn-primary px-6">Search</button>
        </div>
      </form>

      <div class="flex flex-wrap justify-center gap-6 md:gap-10 text-center">
        <div>
          <div class="text-3xl font-bold text-[var(--color-foreground)]">{fmtNum(politicianCount)}</div>
          <div class="text-sm text-[var(--color-muted)]">Politicians</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-[var(--color-foreground)]">{fmtNum(entityCount)}</div>
          <div class="text-sm text-[var(--color-muted)]">Organizations</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-[var(--color-foreground)]">{fmtMoney(totalContributions ? parseFloat(totalContributions) : null)}</div>
          <div class="text-sm text-[var(--color-muted)]">PAC Contributions</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-[var(--color-foreground)]">{fmtMoney(totalLobbying ? parseFloat(totalLobbying) : null)}</div>
          <div class="text-sm text-[var(--color-muted)]">Lobbying Spending</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Top Recipients -->
  <section class="py-10 md:py-14">
    <div class="container">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold">Top Recipients</h2>
        <a href="/politicians/" class="text-sm text-[var(--color-accent)] hover:underline">All politicians &rarr;</a>
      </div>
      <div class="grid gap-3">
        {topPoliticians.slice(0, 10).map((p, i) => (
          <a href={`/politician/${p.fec_id}`} class="card flex items-center gap-4 hover:no-underline py-3 px-4">
            <span class="text-lg font-bold text-[var(--color-muted)] w-6 text-right">#{i + 1}</span>
            <div class="flex-1 min-w-0">
              <div class="font-medium text-[var(--color-foreground)]">{p.name}</div>
              <div class="text-xs text-[var(--color-muted)]">
                <span class={partyClass(p.party)}>{partyLabel(p.party)}</span>
                {p.state ? ` - ${p.state}` : ''} &middot; {officeLabel(p.office)}
              </div>
            </div>
            <div class="text-right">
              <div class="text-sm font-medium text-[var(--color-foreground)]">{fmtMoney(p.total_received)}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Biggest Spenders -->
  <section class="py-10 md:py-14 bg-[var(--color-card)]">
    <div class="container">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold">Biggest Spenders</h2>
        <a href="/organizations/" class="text-sm text-[var(--color-accent)] hover:underline">All organizations &rarr;</a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {topEntities.slice(0, 9).map(e => (
          <a href={`/organization/${e.id}`} class="card hover:no-underline">
            <div class="font-medium text-[var(--color-foreground)] mb-1 truncate">{e.name}</div>
            <div class="text-xs text-[var(--color-muted)] mb-2 capitalize">{e.type || 'Organization'}</div>
            <div class="flex justify-between text-sm">
              <span class="text-[var(--color-muted)]">Total influence</span>
              <span class="font-medium">{fmtMoney(e.total_influence)}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Top Lobbying Issues -->
  <section class="py-10 md:py-14">
    <div class="container">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold">Top Lobbying Issues</h2>
        <a href="/issues/" class="text-sm text-[var(--color-accent)] hover:underline">All issues &rarr;</a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {topIssues.slice(0, 9).map(issue => (
          <a href={`/issue/${issue.code}`} class="card hover:no-underline">
            <div class="font-medium text-[var(--color-foreground)] mb-1">{issue.name}</div>
            <div class="flex justify-between text-sm">
              <span class="text-[var(--color-muted)]">{issue.entity_count} organizations</span>
              <span class="font-medium">{fmtMoney(issue.total_spending)}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Guides -->
  <section class="py-10 md:py-14 bg-[var(--color-card)]">
    <div class="container">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold">Understanding Political Money</h2>
        <a href="/guides/" class="text-sm text-[var(--color-accent)] hover:underline">All guides &rarr;</a>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        <a href="/guides/follow-the-money" class="card hover:no-underline group py-4 px-4">
          <div class="font-medium text-[var(--color-foreground)] group-hover:text-[var(--color-accent)] transition-colors mb-1">Follow the Money</div>
          <p class="text-xs text-[var(--color-muted)]">How to look up any politician's donors using FEC campaign finance data.</p>
        </a>
        <a href="/guides/top-government-contractors" class="card hover:no-underline group py-4 px-4">
          <div class="font-medium text-[var(--color-foreground)] group-hover:text-[var(--color-accent)] transition-colors mb-1">Top Government Contractors</div>
          <p class="text-xs text-[var(--color-muted)]">Who gets the most federal money and how contract awards work.</p>
        </a>
        <a href="/guides/lobbying-explained" class="card hover:no-underline group py-4 px-4">
          <div class="font-medium text-[var(--color-foreground)] group-hover:text-[var(--color-accent)] transition-colors mb-1">Lobbying in America</div>
          <p class="text-xs text-[var(--color-muted)]">Who spends billions to influence policy and how Senate LDA disclosures work.</p>
        </a>
        <a href="/guides/campaign-finance-101" class="card hover:no-underline group py-4 px-4">
          <div class="font-medium text-[var(--color-foreground)] group-hover:text-[var(--color-accent)] transition-colors mb-1">Campaign Finance 101</div>
          <p class="text-xs text-[var(--color-muted)]">PACs, Super PACs, dark money, and how political money flows.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Data source disclaimer -->
  <section class="py-8">
    <div class="container">
      <p class="text-xs text-[var(--color-muted)] text-center max-w-3xl mx-auto">
        Data sourced from the Federal Election Commission (FEC) bulk data (2024 cycle),
        Senate Lobbying Disclosure Act (LDA) filings (2023-2024), and USAspending.gov
        federal contracts. Entity resolution links organizations across all three databases.
        This site is for informational purposes only and is not affiliated with any government agency.
      </p>
    </div>
  </section>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "PlainInfluence",
    "url": "https://plaininfluence.com",
    "description": "Campaign donations, lobbying expenditures, and federal contracts in one place. Follow the money in U.S. politics."
  })} />

  {/* JSON-LD: WebSite + SearchAction */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "PlainInfluence",
    "url": import.meta.env.SITE,
    "potentialAction": {
      "@type": "SearchAction",
      "target": `${import.meta.env.SITE}/?q={search_term_string}`,
      "query-input": "required name=search_term_string"
    }
  })} />

  <!-- FAQ Section -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold mb-6">Frequently Asked Questions</h2>
    <div class="space-y-3">
      <details class="group border border-[var(--color-border)] rounded-lg">
        <summary class="flex items-center justify-between p-4 cursor-pointer font-medium">
          Where does PlainInfluence get its political money data?
          <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="px-4 pb-4 text-[var(--color-muted)] text-sm leading-relaxed">Data comes from three federal sources: the Federal Election Commission (FEC) for campaign contributions, the Senate Office of Public Records for lobbying disclosures under the LDA, and USAspending.gov for government contract data.</div>
      </details>
      <details class="group border border-[var(--color-border)] rounded-lg">
        <summary class="flex items-center justify-between p-4 cursor-pointer font-medium">
          How many politicians and entities are tracked?
          <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="px-4 pb-4 text-[var(--color-muted)] text-sm leading-relaxed">PlainInfluence tracks over 7,100 politicians and nearly 10,000 entities (corporations, PACs, and lobbying firms) across 79 lobbying issue categories.</div>
      </details>
      <details class="group border border-[var(--color-border)] rounded-lg">
        <summary class="flex items-center justify-between p-4 cursor-pointer font-medium">
          Is PlainInfluence free?
          <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="px-4 pb-4 text-[var(--color-muted)] text-sm leading-relaxed">Yes, PlainInfluence is completely free. You can search politicians, entities, and lobbying data without any account or payment. All data comes from public federal disclosures.</div>
      </details>
      <details class="group border border-[var(--color-border)] rounded-lg">
        <summary class="flex items-center justify-between p-4 cursor-pointer font-medium">
          How current is the lobbying and contribution data?
          <svg class="w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="px-4 pb-4 text-[var(--color-muted)] text-sm leading-relaxed">FEC contribution data and Senate lobbying disclosures are updated as new filings become available. Lobbying disclosures are filed quarterly, while FEC data is updated on a rolling basis.</div>
      </details>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Where does PlainInfluence get its political money data?", "acceptedAnswer": { "@type": "Answer", "text": "Data comes from three federal sources: the Federal Election Commission (FEC) for campaign contributions, the Senate Office of Public Records for lobbying disclosures under the LDA, and USAspending.gov for government contract data." } },
      { "@type": "Question", "name": "How many politicians and entities are tracked?", "acceptedAnswer": { "@type": "Answer", "text": "PlainInfluence tracks over 7,100 politicians and nearly 10,000 entities (corporations, PACs, and lobbying firms) across 79 lobbying issue categories." } },
      { "@type": "Question", "name": "Is PlainInfluence free?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, PlainInfluence is completely free. You can search politicians, entities, and lobbying data without any account or payment. All data comes from public federal disclosures." } },
      { "@type": "Question", "name": "How current is the lobbying and contribution data?", "acceptedAnswer": { "@type": "Answer", "text": "FEC contribution data and Senate lobbying disclosures are updated as new filings become available. Lobbying disclosures are filed quarterly, while FEC data is updated on a rolling basis." } }
    ]
  })} />

  <!-- Cross-Portal Links -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-xl font-bold mb-4">Explore More Data</h2>
    <p class="text-sm text-[var(--color-muted)] mb-4">Related government data portals from the Plain Data network:</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <a href="https://plainspending.com" class="block p-4 border border-[var(--color-border)] rounded-lg hover:border-[var(--color-primary)] transition-colors" rel="noopener">
          <span class="font-semibold text-[var(--color-primary)]">PlainSpending</span>
          <span class="block text-sm text-[var(--color-muted)] mt-1">Federal government spending data from USASpending — track contract awards, grants, and agency budgets</span>
        </a>
        <a href="https://plaingovjobs.com" class="block p-4 border border-[var(--color-border)] rounded-lg hover:border-[var(--color-primary)] transition-colors" rel="noopener">
          <span class="font-semibold text-[var(--color-primary)]">PlainGovJobs</span>
          <span class="block text-sm text-[var(--color-muted)] mt-1">Federal workforce data from OPM — 115 agencies, GS pay scale, and workforce demographics</span>
        </a>
    </div>
  </section>

</Base>
